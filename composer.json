{
    "name": "jalismahamud/traffic-analytics",
    "description": "A Laravel package for traffic and activity logging with analytics dashboard",
    "keywords": ["laravel", "traffic", "analytics", "logging", "activity-log"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Jalis Mahamud",
            "email": "jalismahamud31@email.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Jalismahamud\\TrafficAnalytics\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jalismahamud\\TrafficAnalytics\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jalismahamud\\TrafficAnalytics\\TrafficAnalyticsServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}